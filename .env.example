# Local demo mode skips Supabase auth, database writes, and Stripe billing.
NEXT_PUBLIC_DEMO_MODE=true

# Public app URL used by auth and Stripe redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gemini / Google AI Studio
# GOOGLE_API_KEY is preferred; GEMINI_API_KEY is also supported by the app.
# If GOOGLE_SERVICE_ACCOUNT_JSON is set, analysis/TTS use Vertex AI by default.
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_BASE_URL=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_SERVICE_ACCOUNT_JSON=

# FlowAPI / flow2api-compatible service.
# This project expects an OpenAI-compatible /v1/chat/completions endpoint.
# FLOW2API_* aliases are supported for compatibility with the TK426 deployment.
FLOW_API_BASE_URL=http://127.0.0.1:38000
FLOW_API_KEY=han1234
# FLOW2API_BASE_URL=https://flow-api.tk365.xyz
# FLOW2API_API_KEY=han1234

# Supabase is optional in demo mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe is optional in demo mode.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
